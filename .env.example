# Backend — local dev uses PGlite (embedded Postgres in WASM, no Docker needed)
DATABASE_PATH=./.pglite
PORT=3000
NODE_ENV=development

# Production / Supabase — set DATABASE_URL to switch from PGlite to managed Postgres.
# Use the Supabase **Transaction pooler** string (port 6543) for serverless/Vercel.
# Supabase dashboard → Project Settings → Database → Connection string → "URI" (pooler).
# DATABASE_URL=postgresql://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Auth (MVP-003) — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-prod-min-32-chars-long-please

# Frontend
VITE_API_URL=http://localhost:3000

# EFMD: SIA e-Factura Moldova (SFS) — integrare semiautomatizată.
# Fără username+password clientul rulează în MOCK MODE (răspunsuri simulate).
# Cont API: SFS web → Setări → Utilizatorii companiei → „CREEAZĂ UN UTILIZATOR API".
EFACTURA_MD_ENDPOINT=https://api-test.fisc.md/Service.svc
EFACTURA_MD_USERNAME=
EFACTURA_MD_PASSWORD=
EFACTURA_MD_SUPPLIER_IDNO=
EFACTURA_MD_BANK_ACCOUNT=
# EFACTURA_MD_MOCK=1  # forțează mock chiar și cu credențiale (pentru demo)
