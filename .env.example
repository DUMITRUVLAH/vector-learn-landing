# Backend — local dev uses PGlite (embedded Postgres in WASM, no Docker needed)
DATABASE_PATH=./.pglite
PORT=3000
NODE_ENV=development

# Production / Supabase — set DATABASE_URL to switch from PGlite to managed Postgres.
# Use the Supabase **Transaction pooler** string (port 6543) for serverless/Vercel.
# Supabase dashboard → Project Settings → Database → Connection string → "URI" (pooler).
# DATABASE_URL=postgresql://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Auth (MVP-003) — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-prod-min-32-chars-long-please

# Frontend
VITE_API_URL=http://localhost:3000

# Email — Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@notifications.vectorlearn.md

# AUTOBILL — daily recurring-billing cron (Vercel Cron hits /api/fin/cron/run-recurring).
# Vercel auto-attaches "Authorization: Bearer $CRON_SECRET" when this is set; the endpoint
# rejects any request without it. Generate with: openssl rand -base64 32
# CRON_SECRET=change-me-to-a-long-random-string
